# Server
PORT=5001
NODE_ENV=development

# Must match INTERNAL_API_KEY in port 5000 .env
INTERNAL_API_KEY=your-internal-api-key-change-this

# Google OAuth (same credentials as port 5000)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Database (same credentials as port 5000)
DATABASE_URL="postgresql://postgres:password@localhost:5432/ap_dashboard?pgbouncer=true"